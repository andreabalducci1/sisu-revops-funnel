# SiSu RevOps Funnel — environment variables
# Copy this file to .env and fill in the values as you go.
# Every integration degrades gracefully when its key is missing (demo mode).

# ── Anthropic (AI maturity report) ────────────────────────
# API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model id for the report. Sonnet-class recommended (quality sells the offer).
# Cheaper fallback: claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-5

# ── Airtable (lead CRM) ───────────────────────────────────
# Token: https://airtable.com/create/tokens
# Scopes: data.records:read/write, schema.bases:read/write
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ID=Leads

# ── Resend (report + notification emails) ─────────────────
# Key: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── PostHog (funnel analytics) ────────────────────────────
# Project API key (phc_...): Settings -> Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# For the /admin dashboard:
# Personal API key: https://eu.posthog.com/settings/user-api-keys
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# ── Admin (protects the /admin dashboard) ─────────────────
ADMIN_SECRET=

# ── App ───────────────────────────────────────────────────
# Local: http://localhost:3000. In prod: your Vercel or custom domain URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Note: Cal.com (booking) is configured in config.ts > booking
# (calUsername + calEventSlug), not here (they are public values).
